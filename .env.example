# 数据库配置
DATABASE_URL="postgresql://abc@localhost:5432/abc"

# Redis 配置
REDIS_URL="redis://localhost:6379/0"

# 加密密钥（用于加密第三方 API Key，必须配置）
ENCRYPTION_SECRET="please_change_to_a_secure_random_string"

# 允许跨域来源（逗号分隔，生产环境请填写正式域名）
CORS_ORIGIN="https://app.example.com"

# API Server 端口
PORT=8080

VITE_DESKTOP_PORT=5173

VITE_DESKTOP_SHARE_HOST=http://你的局域网IP:5174

# 认证配置
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key"

# WebSocket 端口
WS_PORT=3001

# Desktop 渲染端调用 API 地址
VITE_API_BASE_URL="http://localhost:8080"

# 默认管理员账号（首次启动自动创建）
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin@123456"
ADMIN_NICKNAME="系统管理员"

# Admin 管理后台配置
VITE_ADMIN_PORT=5180
VITE_ADMIN_API_BASE_URL="http://localhost:8080"
VITE_ADMIN_WS_URL="ws://localhost:8080/admin/ws"
VITE_ADMIN_ROUTE_BASE="/admin"
VITE_ADMIN_LOGIN_USERNAME="admin@example.com"
VITE_ADMIN_LOGIN_PASSWORD="Admin@123456"

# 知识库文件存储路径（API server 本地磁盘）
LIBRARY_STORAGE_PATH="./library_files"